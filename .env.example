OPENAI_API_KEY=
SERPAPI_API_KEY=

# Failure alerts — Gmail SMTP (uses Google App Password, NOT your account password)
# To create an app password: myaccount.google.com → Security → 2-Step Verification → App passwords
SMTP_APP_PASSWORD=
SMTP_FROM_EMAIL=barnscarter@gmail.com
SMTP_TO_EMAIL=barnscarter@gmail.com

# Crew model routing
CREWAI_RESEARCH_MODEL=openai/gpt-4o-mini
CREWAI_EXEC_MODEL=openai/gpt-4o
CREWAI_TEMPERATURE=0.2
CREWAI_VERBOSE=false

# Website / WordPress action adapter
WORDPRESS_SITE_CONFIG=C:\Workspace\Active\SEO-Agents-App\config\wordpress-sites\grizzly.json
WORDPRESS_ACTION_ADAPTER=C:\Workspace\Active\SEO-Agents-App\scripts\wordpress-action-adapter.mjs
WORDPRESS_BROWSER_SESSION_DIR=C:\Workspace\Shared\Agents\BrowserSessions\grizzly-wordpress

# GBP action adapter
GBP_POSTER_SCRIPT=C:\Users\carte\.claude\skills\gbp-poster\driver.mjs
GBP_POSTER_CONFIG=C:\Users\carte\.codex\plugins\grizzly-gbp-poster\config.local.json
GBP_BROWSER_SESSION_DIR=C:\Users\carte\.claude\gbp-session
# GBP_POSTER_TIMEOUT_S=420            # max seconds for a live browser post run
# GBP_POSTER_HEADLESS=0               # set 1 to run live GBP posts headless (no visible browser)
# WORDPRESS_ADAPTER_TIMEOUT_S=300

# Executor completion reports: structured JSON (default) vs legacy markdown regex parsing
# CREWAI_STRUCTURED_COMPLETIONS=true

# Optional per-tier local routing (OpenAI-compatible server, e.g. llama-server)
# CREWAI_RESEARCH_API_BASE=http://127.0.0.1:8080/v1
# CREWAI_RESEARCH_API_KEY=local
# CREWAI_RESEARCH_MAX_TOKENS=2048
# CREWAI_EXEC_API_BASE=
# CREWAI_EXEC_API_KEY=
# CREWAI_EXEC_MAX_TOKENS=
